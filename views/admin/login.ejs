<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@600;700;800&family=Source+Sans+3:wght@400;600&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Source Sans 3', sans-serif;
      background: linear-gradient(135deg, #0a1628 0%, #1a3a5c 50%, #0d2137 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .login-card {
      background: #fff;
      border-radius: 16px;
      padding: 3rem 2.5rem;
      width: 100%;
      max-width: 420px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    }
    .login-logo {
      text-align: center;
      margin-bottom: 2rem;
    }
    .login-logo .icon { font-size: 3rem; }
    .login-logo h1 {
      font-family: 'Outfit', sans-serif;
      color: #1a3a5c;
      font-size: 1.8rem;
      margin-top: 0.5rem;
    }
    .login-logo p { color: #666; font-size: 0.9rem; }
    .form-group { margin-bottom: 1.2rem; }
    label {
      display: block;
      font-weight: 600;
      margin-bottom: 0.4rem;
      color: #333;
      font-size: 0.9rem;
    }
    input[type="email"], input[type="password"] {
      width: 100%;
      padding: 0.8rem 1rem;
      border: 2px solid #e0e0e0;
      border-radius: 8px;
      font-size: 1rem;
      font-family: inherit;
      transition: border-color 0.2s;
    }
    input:focus {
      outline: none;
      border-color: #1a3a5c;
    }
    .btn-login {
      width: 100%;
      padding: 0.9rem;
      background: #1a3a5c;
      color: #fff;
      border: none;
      border-radius: 8px;
      font-size: 1.1rem;
      font-weight: 700;
      font-family: 'Outfit', sans-serif;
      letter-spacing: 0.05em;
      cursor: pointer;
      transition: background 0.2s;
      margin-top: 0.5rem;
    }
    .btn-login:hover { background: #e63946; }
    .error-msg {
      background: #fee;
      color: #c00;
      padding: 0.8rem;
      border-radius: 8px;
      margin-bottom: 1rem;
      font-size: 0.9rem;
      text-align: center;
    }
    .back-link {
      display: block;
      text-align: center;
      margin-top: 1.5rem;
      color: #888;
      text-decoration: none;
      font-size: 0.85rem;
    }
    .back-link:hover { color: #1a3a5c; }
  </style>
</head>
<body>
  <div class="login-card">
    <div class="login-logo">
      <div class="icon">🏹</div>
      <h1>FATARCO Admin</h1>
      <p>Panel de Administración</p>
    </div>
    <% if (error) { %>
    <div class="error-msg"><%= error %></div>
    <% } %>
    <form method="POST" action="/admin/login">
      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required placeholder="admin@fatarco.org.ar">
      </div>
      <div class="form-group">
        <label for="password">Contraseña</label>
        <input type="password" id="password" name="password" required placeholder="••••••••">
      </div>
      <button type="submit" class="btn-login">INGRESAR</button>
    </form>
    <a href="/" class="back-link">← Volver al sitio</a>
  </div>
</body>
</html>
