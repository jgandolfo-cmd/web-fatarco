<%- include('partials/header') %>

<!-- Hero -->
<section class="hero" aria-label="Noticia destacada">
  <% if (destacada) { %>
  <div class="hero-bg" style="background-image: url('<%= destacada.imagen || '' %>')" role="img" aria-label="<%= destacada.titulo %>"></div>
  <% } else { %>
  <div class="hero-bg hero-default"></div>
  <% } %>
  <div class="hero-overlay"></div>
  <div class="container hero-inner">
    <div class="hero-content">
      <% if (destacada) { %>
      <span class="hero-badge"><%= destacada.categoria %></span>
      <h1 class="hero-title"><%= destacada.titulo %></h1>
      <p class="hero-excerpt"><%= destacada.extracto %></p>
      <a href="/noticia/<%= destacada.slug %>" class="btn btn-primary">Leer más →</a>
      <% } else { %>
      <span class="hero-badge">Federación Argentina de Tiro con Arco</span>
      <h1 class="hero-title">Argentina Apunta</h1>
      <p class="hero-excerpt">Promovemos la excelencia deportiva, la inclusión y el desarrollo del tiro con arco en todo el país.</p>
      <div style="display:flex;gap:0.65rem;flex-wrap:wrap">
        <a href="/noticias" class="btn btn-primary">Noticias</a>
        <a href="/el-deporte" class="btn btn-outline">Conocer el deporte</a>
      </div>
      <% } %>
    </div>
  </div>
</section>

<!-- Noticias -->
<section class="section" aria-label="Últimas noticias">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Últimas Noticias</h2>
      <a href="/noticias" class="section-link">Ver todas →</a>
    </div>
    <% if (noticias.length > 0) { %>
    <div class="news-grid">
      <div class="news-grid__main">
        <% const main = noticias[0]; %>
        <article class="card card--featured">
          <% if (main.imagen) { %>
          <div class="card__img" style="background-image:url('<%= main.imagen %>')" role="img" aria-label="<%= main.titulo %>"></div>
          <% } else { %>
          <div class="card__img card__img--placeholder"></div>
          <% } %>
          <div class="card__body">
            <span class="card__cat"><%= main.categoria %></span>
            <h3 class="card__title"><a href="/noticia/<%= main.slug %>"><%= main.titulo %></a></h3>
            <p class="card__excerpt"><%= main.extracto %></p>
            <time class="card__date" datetime="<%= main.created_at %>"><%= new Date(main.created_at).toLocaleDateString('es-AR', { day: 'numeric', month: 'long', year: 'numeric' }) %></time>
          </div>
        </article>
      </div>
      <div class="news-grid__sidebar">
        <% noticias.slice(1, 5).forEach(n => { %>
        <article class="card card--mini">
          <% if (n.imagen) { %>
          <div class="card__img" style="background-image:url('<%= n.imagen %>')"></div>
          <% } else { %>
          <div class="card__img card__img--placeholder"></div>
          <% } %>
          <div class="card__body">
            <span class="card__cat"><%= n.categoria %></span>
            <h3 class="card__title"><a href="/noticia/<%= n.slug %>"><%= n.titulo %></a></h3>
            <time class="card__date" datetime="<%= n.created_at %>"><%= new Date(n.created_at).toLocaleDateString('es-AR', { day: 'numeric', month: 'short' }) %></time>
          </div>
        </article>
        <% }) %>
      </div>
    </div>
    <% } %>
  </div>
</section>

<!-- Eventos -->
<section class="section section--gray" aria-label="Próximos eventos">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Próximos Eventos</h2>
      <a href="/eventos" class="section-link">Calendario →</a>
    </div>
    <div class="eventos-list" role="list">
      <% eventos.forEach(ev => { 
        const fecha = new Date(ev.fecha_inicio + 'T12:00:00');
        const dia = fecha.getDate().toString().padStart(2, '0');
        const mes = fecha.toLocaleDateString('es-AR', { month: 'short' }).toUpperCase().replace('.','');
      %>
      <div class="evento-row" role="listitem">
        <div class="evento-fecha">
          <span class="evento-dia"><%= dia %></span>
          <span class="evento-mes"><%= mes %></span>
        </div>
        <div class="evento-tipo tipo-<%= ev.tipo.toLowerCase() %>" aria-label="<%= ev.tipo %>"><%= ev.tipo %></div>
        <div>
          <div class="evento-titulo"><%= ev.titulo %></div>
          <span class="evento-lugar"><%= ev.localidad %><% if (ev.provincia) { %>, <%= ev.provincia %><% } %></span>
        </div>
        <div class="evento-arrow" aria-hidden="true">→</div>
      </div>
      <% }) %>
      <% if (eventos.length === 0) { %>
      <p class="empty-state">No hay eventos próximos programados.</p>
      <% } %>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-section">
  <div class="container cta-content">
    <h2>Empezá a tirar con arco</h2>
    <p>Un deporte para todas las edades y capacidades. Encontrá un club cerca tuyo.</p>
    <div class="cta-buttons">
      <a href="/clubes" class="btn btn-primary">Encontrar clubes</a>
      <a href="/el-deporte" class="btn btn-outline">Conocer el deporte</a>
    </div>
  </div>
</section>

<!-- Sponsors -->
<% if (sponsors && sponsors.length > 0) { %>
<section class="sponsors-section" aria-label="Sponsors">
  <div class="container">
    <div class="sponsors-bar">
      <% sponsors.forEach(s => { %>
      <a href="<%= s.url || '#' %>" class="sponsor-logo" target="_blank" rel="noopener" title="<%= s.nombre %>">
        <% if (s.logo) { %><img src="<%= s.logo %>" alt="<%= s.nombre %>" loading="lazy"><% } else { %><span><%= s.nombre %></span><% } %>
      </a>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<%- include('partials/footer') %>
